{
	"name": "mangoweb/presenter-tester",
	"license": "MIT",
	"require": {
		"php": ">=8.1",
		"nette/application": "~3.0",
		"nette/security": "~3.0",
		"nette/forms": "~3.0",
		"nette/tester": "~2.0",
		"mangoweb/tester-http-mocks": "^0.5"
	},
	"require-dev": {
		"nextras/secured-links": "@dev",
		"mangoweb/tester-infrastructure": "@dev",
		"phpstan/phpstan": "^0.12",
		"latte/latte": "^2.4"
	},
	"autoload": {
		"classmap": [
			"src"
		]
	},
	"autoload-dev": {
		"classmap": ["tests/inc"]
	},
	"repositories": {
		"tester-http-mocks": {
			"type": "vcs",
			"url": "https://github.com/adbrosaci/tester-http-mocks"
		}
	}
}
